pipeline {

    agent {
        label 'master'
    }

    environment {

        AWS_REGION = 'eu-north-1'
        AWS_ACCOUNT_ID = '138035228373'

        IMAGE_REPO = 'devopshub/backend'
        IMAGE_TAG = "${BUILD_NUMBER}"

        EKS_CLUSTER = 'devopshub-prod-cluster'

        NAMESPACE = 'devopshub'
    }


    stages {


        stage('Checkout Code') {

            steps {

                git branch: 'main',
                url: 'https://github.com/rohitarame/DevOpsHub.git'

            }
        }



        stage('Build Backend') {

            steps {

                dir('backend') {

                    sh '''
                    mvn clean package -DskipTests
                    '''

                }
            }
        }



        stage('AWS Login & ECR') {

            steps {

                withCredentials([
                    [$class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-credentials']
                ]) {


                    sh '''

                    aws sts get-caller-identity


                    aws ecr get-login-password \
                    --region ${AWS_REGION} | \
                    docker login \
                    --username AWS \
                    --password-stdin \
                    ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com


                    '''

                }
            }
        }




        stage('Docker Build') {

            steps {

                dir('backend') {

                    sh '''

                    docker build \
                    -t ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${IMAGE_REPO}:${IMAGE_TAG} .


                    '''

                }
            }
        }




        stage('Push Backend Image') {

            steps {

                sh '''

                docker push \
                ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${IMAGE_REPO}:${IMAGE_TAG}


                '''

            }
        }





        stage('Connect EKS') {

            steps {

                withCredentials([
                    [$class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-credentials']
                ]) {


                    sh '''

                    aws eks update-kubeconfig \
                    --region ${AWS_REGION} \
                    --name ${EKS_CLUSTER}


                    kubectl get nodes


                    '''

                }

            }

        }





        stage('Deploy Kubernetes Manifests') {

            steps {


                sh '''

                cd k8s


                echo "Creating Namespace"

                kubectl apply -f namespace.yaml



                echo "Applying ConfigMap"

                kubectl apply -f configmap.yaml



                echo "Applying Secrets"

                kubectl apply -f secret.yaml



                echo "Deploying MongoDB"

                kubectl apply -f mongodb-deployment.yaml

                kubectl apply -f mongodb-service.yaml



                echo "Deploying Backend"

                kubectl apply -f backend-deployment.yaml

                kubectl apply -f backend-service.yaml



                echo "Deploying Frontend"

                kubectl apply -f frontend-deployment.yaml

                kubectl apply -f frontend-service.yaml



                echo "Checking Pods"


                kubectl get pods -n ${NAMESPACE}


                '''


            }

        }



        stage('Update Backend Image') {

            steps {


                sh '''

                kubectl set image deployment/backend \
                backend=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${IMAGE_REPO}:${IMAGE_TAG} \
                -n ${NAMESPACE}



                kubectl rollout status deployment/backend \
                -n ${NAMESPACE}


                '''

            }

        }


    }



    post {


        success {

            echo '✅ Complete DevOpsHub Deployment Completed Successfully'

        }


        failure {

            echo '❌ Deployment Failed'

        }

    }

}
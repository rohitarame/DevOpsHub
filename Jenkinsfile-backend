pipeline {

    agent {
        label 'master'
    }


    environment {

        AWS_REGION = 'eu-north-1'
        AWS_ACCOUNT_ID = '138035228373'

        IMAGE_REPO = 'devopshub/backend'
        IMAGE_TAG = "${BUILD_NUMBER}"

        EKS_CLUSTER = 'devopshub-prod-cluster'

        NAMESPACE = 'devopshub'

        KUBECONFIG = '/var/lib/jenkins/.kube/config'
    }


    stages {


        stage('Checkout Code') {

            steps {

                git branch: 'main',
                url: 'https://github.com/rohitarame/DevOpsHub.git'

            }
        }



        stage('Build Backend') {

            steps {

                dir('backend') {

                    sh '''

                    mvn clean package -DskipTests

                    '''

                }

            }
        }



        stage('AWS Login & ECR') {

            steps {

                withCredentials([
                    [$class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-credentials']
                ]) {


                    sh '''

                    aws sts get-caller-identity


                    aws ecr get-login-password \
                    --region ${AWS_REGION} | \
                    docker login \
                    --username AWS \
                    --password-stdin \
                    ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com


                    '''

                }

            }

        }




        stage('Docker Build') {

            steps {

                dir('backend') {

                    sh '''

                    docker build \
                    -t ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${IMAGE_REPO}:${IMAGE_TAG} .


                    '''

                }

            }

        }





        stage('Push Image To ECR') {

            steps {

                sh '''

                docker push \
                ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${IMAGE_REPO}:${IMAGE_TAG}

                '''

            }

        }





        stage('Connect EKS Cluster') {

            steps {


                withCredentials([
                    [$class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-credentials']
                ]) {


                    sh '''

                    mkdir -p /var/lib/jenkins/.kube


                    aws eks update-kubeconfig \
                    --region ${AWS_REGION} \
                    --name ${EKS_CLUSTER} \
                    --kubeconfig ${KUBECONFIG}



                    kubectl get nodes \
                    --kubeconfig ${KUBECONFIG}



                    '''

                }


            }

        }





        stage('Deploy Kubernetes') {

            steps {


                sh '''

                cd k8s


                echo "Creating Namespace"

                kubectl apply \
                --kubeconfig ${KUBECONFIG} \
                -f namespace.yaml \
                --validate=false



                kubectl apply \
                --kubeconfig ${KUBECONFIG} \
                -f configmap.yaml \
                --validate=false



                kubectl apply \
                --kubeconfig ${KUBECONFIG} \
                -f secret.yaml \
                --validate=false




                echo "Deploy MongoDB"


                kubectl apply \
                --kubeconfig ${KUBECONFIG} \
                -f mongodb-deployment.yaml \
                --validate=false


                kubectl apply \
                --kubeconfig ${KUBECONFIG} \
                -f mongodb-service.yaml \
                --validate=false




                echo "Deploy Backend"


                kubectl apply \
                --kubeconfig ${KUBECONFIG} \
                -f backend-deployment.yaml \
                --validate=false


                kubectl apply \
                --kubeconfig ${KUBECONFIG} \
                -f backend-service.yaml \
                --validate=false




                echo "Deploy Frontend"


                kubectl apply \
                --kubeconfig ${KUBECONFIG} \
                -f frontend-deployment.yaml \
                --validate=false


                kubectl apply \
                --kubeconfig ${KUBECONFIG} \
                -f frontend-service.yaml \
                --validate=false




                kubectl get pods \
                -n ${NAMESPACE} \
                --kubeconfig ${KUBECONFIG}



                '''

            }

        }





        stage('Update Backend Image') {


            steps {


                sh '''


                kubectl set image deployment/backend \
                backend=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${IMAGE_REPO}:${IMAGE_TAG} \
                -n ${NAMESPACE} \
                --kubeconfig ${KUBECONFIG}



                kubectl rollout status deployment/backend \
                -n ${NAMESPACE} \
                --kubeconfig ${KUBECONFIG}



                '''

            }

        }


    }



    post {


        success {

            echo '✅ Complete DevOpsHub Deployment Completed Successfully'

        }


        failure {

            echo '❌ DevOpsHub Deployment Failed'

        }


    }


}